{
  "providers": {
    "ollama": {
      "apiKey": "dummy",
      "apiBase": "${OLLAMA_API_BASE_HOST_PORT}"
    }
  },
  "agents": {
    "defaults": {
      "model": "${SLM_MODEL_NAME}",
      "max_tokens": 4096,
      "temperature": 0.7,
      "workspace": "${AETHER_HOME}/workspace",
      "embedding_model": "${AETHER_HOME}/models/${EMBEDDING_MODEL_NAME}",
      "chunk_size": 1000,
      "chunk_overlap": 100,
      "top_k": 5,
      "similarity_threshold": 0.0,
      "batch_size": 32,
      "timeout": 5
    }
  },
  "mcp": {
    "servers": {
      "rocketmq_mcp": {
        "server_name": "rocketmq_mcp",
        "server_url": "${ROCKETMQ_MCP_SERVER_URL}",
        "message_path": "/mcp/message",
        "auth_token": "dummy",
        "enabled": true
      }
    },
    "auto_discover": true,
    "discovery_path": "${AETHER_HOME}/servers"
  },
  "rerank": {
    "model_path": "${AETHER_HOME}/models/${RERANK_MODEL_NAME}",
    "threshold": 70.0
  }
}